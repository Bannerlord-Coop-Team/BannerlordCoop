{
    var newValue = new {{ElementType}}[data.Length];
    for (int i = 0; i < data.Value.Count; i++)
    {
        newValue[data.Value[i].Index] = data.Value[i].Value;
    }
    instance.{{ MemberName }} = newValue;
});
