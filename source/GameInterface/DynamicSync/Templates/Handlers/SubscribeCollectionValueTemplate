Subscribe<{{MemberType}}, {{ MemberDeclaringType}}_{{ MemberName }}_SetLocalMessage>((instanceId, data) => 
{
    var valueIds = new List<(int Index, {{ElementType}} Value)>();
    for (int i = 0; i < data.Value.Length; i++)
    {
        if (data.Value[i] == null) continue;
        valueIds.Add(new(i, data.Value[i]));
    }
    network.SendAll(new {{ MemberDeclaringType}}_{{ MemberName }}_SetNetworkMessage(instanceId, valueIds, data.Value.Length));
});
SubscribeNetwork<{{MemberType}}, {{ MemberDeclaringType}}_{{ MemberName }}_SetNetworkMessage>((instance, data) => 
{
    var newValue = new MBList<{{ElementType}}>();
    for (int i = 0; i < data.Value.Count; i++)
    {
        newValue.Add(data.Value[i]);
    }
    instance.{{ MemberName }} = newValue;
});
Subscribe<{{ElementType}}, {{ MemberDeclaringType}}_{{ MemberName }}_ArrayChangeLocalMessage>((instanceId, data) => 
{
    network.SendAll(new {{ MemberDeclaringType}}_{{ MemberName }}_ArrayChangeNetworkMessage(instanceId, data.Value));
});
SubscribeNetwork<{{ElementType}}, {{ MemberDeclaringType}}_{{ MemberName }}_ArrayChangeNetworkMessage>((instance, data) => 
{
    instance.Remove(data.Value);
});