Subscribe<{{MemberType}}, {{ MemberDeclaringType}}_{{ MemberName }}_SetLocalMessage>((instanceId, data) => 
{
    var valueIds = new List<{{ElementType}}>();
    for (int i = 0; i < data.Value.Count; i++)
    {
        valueIds.Add(data.Value[i]);
    }
    network.SendAll(new {{ MemberDeclaringType}}_{{ MemberName }}_SetNetworkMessage(instanceId, valueIds));
});
SubscribeNetwork<{{MemberType}}, {{ MemberDeclaringType}}_{{ MemberName }}_SetNetworkMessage>((instance, data) => 
{
    var newValue = new {{MemberType}}();
    for (int i = 0; i < data.Value.Count; i++)
    {
        newValue.Add(data.Value[i]);
    }
    instance.{{ MemberName }} = newValue;
});
Subscribe<{{ElementType}}, {{ MemberDeclaringType}}_{{ MemberName }}_AddLocalMessage>((instanceId, data) => 
{
    if (!objectManager.TryGetId(data.Value, out string id)) return;
    network.SendAll(new {{ MemberDeclaringType}}_{{ MemberName }}_AddNetworkMessage(instanceId, id));
});
SubscribeNetwork<{{ElementType}}, {{ MemberDeclaringType}}_{{ MemberName }}_AddNetworkMessage>((instance, data) => 
{
    if (!objectManager.TryGetObject<{{ElementType}}>(data.ValueId, out {{ElementType}} element)) return;
    instance.{{ MemberName }}.Add(element);
});
