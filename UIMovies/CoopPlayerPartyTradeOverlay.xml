                    HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginRight="520" MarginBottom="72"
                    Brush="Clan.TabControl.Text" Brush.FontSize="24" Text="@LocalAcceptedText"/>
      </Children>
    </Widget>
  </Window>
</Prefab>
