<Prefab>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>
        <Standard.Background/>

        <Standard.TopPanel Parameter.Title="@MovieTextHeader"/>

        <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="1160" HeightSizePolicy="Fixed" SuggestedHeight="650"
                   HorizontalAlignment="Center" VerticalAlignment="Center" MarginTop="20" PositionXOffset="-60"
                   StackLayout.LayoutMethod="HorizontalLeftToRight">
          <Children>
            <!-- Left-side connection-mode menu. -->
            <ListPanel DataSource="{Tabs}" WidthSizePolicy="Fixed" SuggestedWidth="270"
                       HeightSizePolicy="CoverChildren" MarginRight="30"
                       StackLayout.LayoutMethod="VerticalTopToBottom">
              <ItemTemplate>
                <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true"
                              WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="64"
                              MarginBottom="12" Brush="Header.Tab.Center"
                              Command.Click="ExecuteSelection" IsSelected="@IsSelected">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Brush="Clan.TabControl.Text" Brush.FontSize="28"
                                Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center"
                                Text="@Name"/>
                  </Children>
                </ButtonWidget>
              </ItemTemplate>
            </ListPanel>

            <Widget WidthSizePolicy="Fixed" SuggestedWidth="860" HeightSizePolicy="StretchToParent">
              <Children>
                <!-- Direct IP form. -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                           IsVisible="@IsDirectTabVisible"
                           StackLayout.LayoutMethod="VerticalTopToBottom">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="64"
                                MarginBottom="16" Brush="Clan.TabControl.Text" Brush.FontSize="34"
                                Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center"
                                Text="Direct Connection"/>

                    <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="760" HeightSizePolicy="Fixed" SuggestedHeight="76"
                               HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="270" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="28"
                                    Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center"
                                    MarginRight="20" Text="@IpText"/>
                        <EditableTextWidget WidthSizePolicy="Fixed" SuggestedWidth="390" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                            VerticalAlignment="Center" Brush="ScoreboardPanels_2" Brush.AlphaFactor="0.75"
                                            Brush.FontSize="28" Brush.TextHorizontalAlignment="Center"
                                            Brush.TextVerticalAlignment="Center" Text="@Ip"/>
                        <HintWidget DataSource="{ServerAddressHint}" WidthSizePolicy="Fixed" SuggestedWidth="44"
                                    HeightSizePolicy="StretchToParent" MarginLeft="14"
                                    Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint">
                          <Children>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        DoNotAcceptEvents="true" Brush="Clan.TabControl.Text"
                                        Brush.TextVerticalAlignment="Center" Text="(i)"/>
                          </Children>
                        </HintWidget>
                      </Children>
                    </ListPanel>

                    <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="760" HeightSizePolicy="Fixed" SuggestedHeight="76"
                               HorizontalAlignment="Center" IsVisible="@PublicAddressVisible"
                               StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="270" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="28"
                                    Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center"
                                    MarginRight="20" Text="@PublicAddressText"/>
                        <EditableTextWidget WidthSizePolicy="Fixed" SuggestedWidth="390" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                            VerticalAlignment="Center" Brush="ScoreboardPanels_2" Brush.AlphaFactor="0.75"
                                            Brush.FontSize="28" Brush.TextHorizontalAlignment="Center"
                                            Brush.TextVerticalAlignment="Center" Text="@PublicAddress"/>
                        <HintWidget DataSource="{FriendsAddressHint}" WidthSizePolicy="Fixed" SuggestedWidth="44"
                                    HeightSizePolicy="StretchToParent" MarginLeft="14"
                                    Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint">
                          <Children>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        DoNotAcceptEvents="true" Brush="Clan.TabControl.Text"
                                        Brush.TextVerticalAlignment="Center" Text="(i)"/>
                          </Children>
                        </HintWidget>
                      </Children>
                    </ListPanel>

                    <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="760" HeightSizePolicy="Fixed" SuggestedHeight="76"
                               HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="270" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="28"
                                    Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center"
                                    MarginRight="20" Text="@PortText"/>
                        <EditableTextWidget WidthSizePolicy="Fixed" SuggestedWidth="390" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                            VerticalAlignment="Center" Brush="ScoreboardPanels_2" Brush.AlphaFactor="0.75"
                                            Brush.FontSize="28" Brush.TextHorizontalAlignment="Center"
                                            Brush.TextVerticalAlignment="Center" Text="@Port"/>
                        <HintWidget DataSource="{PortHint}" WidthSizePolicy="Fixed" SuggestedWidth="44"
                                    HeightSizePolicy="StretchToParent" MarginLeft="14"
                                    Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint">
                          <Children>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        DoNotAcceptEvents="true" Brush="Clan.TabControl.Text"
                                        Brush.TextVerticalAlignment="Center" Text="(i)"/>
                          </Children>
                        </HintWidget>
                      </Children>
                    </ListPanel>

                    <ListPanel WidthSizePolicy="Fixed" SuggestedWidth="760" HeightSizePolicy="Fixed" SuggestedHeight="76"
                               HorizontalAlignment="Center" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="270" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="28"
                                    Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center"
                                    MarginRight="20" Text="@PasswordText"/>
                        <EditableTextWidget WidthSizePolicy="Fixed" SuggestedWidth="390" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                            VerticalAlignment="Center" Brush="ScoreboardPanels_2" Brush.AlphaFactor="0.75"
                                            Brush.FontSize="28" Brush.TextHorizontalAlignment="Center"
                                            Brush.TextVerticalAlignment="Center" RealText="@Password"
                                            IsObfuscationEnabled="true" MaxLength="128"/>
                        <HintWidget DataSource="{PasswordHint}" WidthSizePolicy="Fixed" SuggestedWidth="44"
                                    HeightSizePolicy="StretchToParent" MarginLeft="14"
                                    Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint">
                          <Children>
                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                        DoNotAcceptEvents="true" Brush="Clan.TabControl.Text"
                                        Brush.TextVerticalAlignment="Center" Text="(i)"/>
                          </Children>
                        </HintWidget>
                      </Children>
                    </ListPanel>

                    <Standard.Button WidthSizePolicy="Fixed" SuggestedWidth="160" HeightSizePolicy="Fixed" SuggestedHeight="64"
                                     HorizontalAlignment="Center" MarginTop="30"
                                     Command.Click="ActionConnect" Parameter.Text="@JoinButtonText"/>
                  </Children>
                </ListPanel>

                <!-- Browsable standalone-server Steam lobbies. -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                           IsVisible="@IsSteamLobbiesTabVisible"
                           StackLayout.LayoutMethod="VerticalTopToBottom">
                  <Children>
                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="64"
                               MarginBottom="10" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="34"
                                    Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center"
                                    Text="@SteamLobbiesHeaderText"/>
                        <Standard.Button WidthSizePolicy="Fixed" SuggestedWidth="150" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                         VerticalAlignment="Center" IsDisabled="@IsRefreshSteamLobbiesDisabled"
                                         Command.Click="ActionRefreshSteamLobbies" Parameter.Text="@RefreshButtonText"/>
                      </Children>
                    </ListPanel>

                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="64"
                               MarginBottom="10" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="145" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="24"
                                    Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center"
                                    Text="@HostSearchLabelText"/>
                        <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                     VerticalAlignment="Center" Brush="SaveLoad.Search.Button"
                                     UpdateChildrenStates="true">
                          <Children>
                            <EditableTextWidget Id="SteamLobbyHostSearchInput" UpdateChildrenStates="true"
                                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                MarginLeft="12" MarginRight="12" MarginTop="8" MarginBottom="8"
                                                Brush="SaveLoad.Search.InputText" Brush.FontSize="24"
                                                Text="@SteamLobbyHostSearchText"
                                                DefaultSearchText="@HostSearchPlaceholderText"
                                                KeyboardInfoText="@HostSearchLabelText" MaxLength="128"/>
                          </Children>
                        </BrushWidget>
                        <Standard.Button WidthSizePolicy="Fixed" SuggestedWidth="150" HeightSizePolicy="Fixed" SuggestedHeight="58"
                                         VerticalAlignment="Center" MarginLeft="12"
                                         IsDisabled="@IsSearchSteamLobbiesDisabled"
                                         Command.Click="ActionSearchSteamLobbies" Parameter.Text="@SearchButtonText"/>
                      </Children>
                    </ListPanel>

                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="52"
                                IsVisible="@IsSteamLobbyStatusVisible" Brush="Clan.TabControl.Text"
                                Brush.FontSize="24" Brush.FontColor="#B8B8B8FF"
                                Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center"
                                Text="@SteamLobbyStatusText"/>

                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="42"
                               MarginLeft="12" MarginRight="18" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="260" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="22" Text="@HostColumnText"/>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="180" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="22" Text="@PasswordColumnText"/>
                        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="200" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="22"
                                    Brush.TextHorizontalAlignment="Center" Text="@ConnectedPlayersColumnText"/>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Brush="Clan.TabControl.Text" Brush.FontSize="22" Text="@CompatibilityColumnText"/>
                      </Children>
                    </ListPanel>

                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="408">
                      <Children>
                        <ScrollablePanel Id="LobbyScrollablePanel" WidthSizePolicy="StretchToParent"
                                         HeightSizePolicy="StretchToParent" MarginRight="18"
                                         AutoHideScrollBars="true" ClipRect="LobbyClipRect"
                                         InnerPanel="LobbyClipRect\LobbyList" VerticalScrollbar="..\LobbyScrollbar">
                          <Children>
                            <Widget Id="LobbyClipRect" WidthSizePolicy="StretchToParent"
                                    HeightSizePolicy="StretchToParent" ClipContents="true">
                              <Children>
                                <NavigatableListPanel Id="LobbyList" DataSource="{SteamLobbies}"
                                                      WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                                      StackLayout.LayoutMethod="VerticalTopToBottom">
                                  <ItemTemplate>
                                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="72"
                                            MarginBottom="8">
                                      <Children>
                                        <ButtonWidget DoNotPassEventsToChildren="true" UpdateChildrenStates="true"
                                                      WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                      Brush="Header.Tab.Center" Command.Click="ExecuteJoin"
                                                      IsDisabled="@IsJoinDisabled">
                                          <Children>
                                            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                       MarginLeft="12" MarginRight="12"
                                                       StackLayout.LayoutMethod="HorizontalLeftToRight">
                                              <Children>
                                                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="260" HeightSizePolicy="StretchToParent"
                                                            Brush="Clan.TabControl.Text" Brush.FontSize="21" ClipContents="true"
                                                            Brush.TextVerticalAlignment="Center" Text="@HostText"/>
                                                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="180" HeightSizePolicy="StretchToParent"
                                                            Brush="Clan.TabControl.Text" Brush.FontSize="21"
                                                            Brush.TextVerticalAlignment="Center" Text="@PasswordText"/>
                                                <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="200" HeightSizePolicy="StretchToParent"
                                                            Brush="Clan.TabControl.Text" Brush.FontSize="21"
                                                            Brush.TextHorizontalAlignment="Center"
                                                            Brush.TextVerticalAlignment="Center" Text="@ConnectedPlayersText"/>
                                                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                            IsVisible="@IsCompatibleStatusVisible"
                                                            Brush="Clan.TabControl.Text" Brush.FontSize="21"
                                                            Brush.FontColor="@StatusColor" Brush.TextVerticalAlignment="Center"
                                                            Text="@StatusText"/>
                                              </Children>
                                            </ListPanel>
                                          </Children>
                                        </ButtonWidget>

                                        <Widget WidthSizePolicy="Fixed" SuggestedWidth="178"
                                                HeightSizePolicy="StretchToParent" HorizontalAlignment="Right"
                                                MarginRight="28" IsVisible="@IsStatusHintVisible">
                                          <Children>
                                            <HintWidget DataSource="{StatusHint}" WidthSizePolicy="StretchToParent"
                                                        HeightSizePolicy="StretchToParent"
                                                        Command.HoverBegin="ExecuteBeginHint" Command.HoverEnd="ExecuteEndHint">
                                              <Children>
                                                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                            DoNotAcceptEvents="true" Brush="Clan.TabControl.Text"
                                                            Brush.FontSize="26" Brush.FontColor="#FF8080FF"
                                                            Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center"
                                                            Text="Incompatible (i)"/>
                                              </Children>
                                            </HintWidget>
                                          </Children>
                                        </Widget>
                                      </Children>
                                    </Widget>
                                  </ItemTemplate>
                                </NavigatableListPanel>
                              </Children>
                            </Widget>
                          </Children>
                        </ScrollablePanel>

                        <ScrollbarWidget Id="LobbyScrollbar" WidthSizePolicy="Fixed" SuggestedWidth="8"
                                         HeightSizePolicy="StretchToParent" HorizontalAlignment="Right"
                                         AlignmentAxis="Vertical" Handle="LobbyScrollbarHandle" MaxValue="100" MinValue="0">
                          <Children>
                            <Widget WidthSizePolicy="Fixed" SuggestedWidth="2" HeightSizePolicy="StretchToParent"
                                    HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#5A4033FF" AlphaFactor="0.2"/>
                            <ImageWidget Id="LobbyScrollbarHandle" WidthSizePolicy="Fixed" SuggestedWidth="4"
                                         HeightSizePolicy="Fixed" SuggestedHeight="10" HorizontalAlignment="Center"
                                         Brush="FaceGen.Scrollbar.Handle" Brush.AlphaFactor="0.7"/>
                          </Children>
                        </ScrollbarWidget>
                      </Children>
                    </Widget>
                  </Children>
                </ListPanel>
              </Children>
            </Widget>
          </Children>
        </ListPanel>

        <Standard.Button Brush="Standard.BackButton" WidthSizePolicy="Fixed" SuggestedWidth="128"
                         HeightSizePolicy="Fixed" SuggestedHeight="64" HorizontalAlignment="Center"
                         VerticalAlignment="Bottom" MarginBottom="44" Command.Click="ActionCancel"/>

        <TextWidget WidthSizePolicy="Fixed" SuggestedWidth="256" HeightSizePolicy="Fixed" SuggestedHeight="64"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right" PositionYOffset="-220" PositionXOffset="-6"
                    Brush="ScoreboardPanels_2" Text="@CommunityText"/>

        <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="60"
                   StackLayout.LayoutMethod="HorizontalLeftToRight">
          <Children>
            <Standard.Button HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Command.Click="ActionGithub" Parameter.Text="@GithubButtonText" PositionXOffset="-20"/>
          </Children>
        </ListPanel>

        <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="10"
                   StackLayout.LayoutMethod="HorizontalLeftToRight">
          <Children>
            <Standard.Button HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Command.Click="ActionDiscord" Parameter.Text="@DiscordButtonText" PositionXOffset="-20"/>
          </Children>
        </ListPanel>

        <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="110"
                   StackLayout.LayoutMethod="HorizontalLeftToRight">
          <Children>
            <Standard.Button HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Command.Click="ActionPatreon" Parameter.Text="@PatreonButtonText" PositionXOffset="-20"/>
          </Children>
        </ListPanel>

        <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="160"
                   StackLayout.LayoutMethod="HorizontalLeftToRight">
          <Children>
            <Standard.Button HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Command.Click="ActionBuyMeACoffee" Parameter.Text="@BuyMeACoffeeButtonText" PositionXOffset="-20"/>
          </Children>
        </ListPanel>
      </Children>
    </Widget>
  </Window>
</Prefab>
